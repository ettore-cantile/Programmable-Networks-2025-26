ip addr add 20.0.1.4/24 dev eth0

/usr/share/openvswitch/scripts/ovs-ctl --system-id=random start
ovs-vsctl add-br s4

ovs-vsctl add-port s4 eth1
ovs-vsctl add-port s4 eth2
ovs-vsctl add-port s4 eth3
ovs-vsctl add-port s4 eth4
ovs-vsctl add-port s4 eth5

ovs-vsctl set-controller s4 tcp:20.0.1.5:6633