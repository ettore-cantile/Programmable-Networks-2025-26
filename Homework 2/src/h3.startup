# Assigning IP address to the interface connected to H
ip link set dev eth0 address 00:00:00:00:00:03
ip addr add 10.0.3.10/24 dev eth0

# Setting default route via H
ip route add default via 10.0.3.1
ip neigh add 10.0.3.1 lladdr 00:00:00:00:00:73 dev eth0

ip link set dev eth0 mtu 1474
ethtool -K eth0 tx off rx off