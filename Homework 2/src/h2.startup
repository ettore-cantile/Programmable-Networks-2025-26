# Assigning IP address to the interface connected to A
ip link set dev eth0 address 00:00:00:00:00:02
ip addr add 10.0.2.10/24 dev eth0

# Setting default route via A ( which acts as the classifier/gateway depending on the traffic )
ip route add default via 10.0.2.1
ip neigh add 10.0.2.1 lladdr 00:00:00:00:00:a2 dev eth0

ip link set dev eth0 mtu 1474
ethtool -K eth0 tx off rx off